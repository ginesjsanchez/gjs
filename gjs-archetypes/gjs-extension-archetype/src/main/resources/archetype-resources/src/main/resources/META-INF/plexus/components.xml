#set( $symbol_pound = '#' )
#set( $symbol_dollar = '$' )
#set( $symbol_escape = '\' )
#set( $capitalizedName = $shortName.substring(0,1).toUpperCase() + $shortName.substring(1))
#set( $capitalizedExtension = $extension.substring(0,1).toUpperCase() + $extension.substring(1))
#set( $infoGroup = $groupId)
#set( $infoArtifact = $artifactId)
#set( $infoVersion = $version)
<component-set>
  <components>
    <component>
      <role>org.apache.maven.artifact.handler.ArtifactHandler</role>
      <role-hint>${extension}</role-hint>
      <implementation>${package}.${capitalizedExtension}ArtifactHandler</implementation>
      <configuration>
        <type>${extension}</type>
        <extension>${extension}</extension>
        <packaging>${extension}</packaging>
        <addedToClasspath>false</addedToClasspath>
      </configuration>
    </component>
    <component>
      <role>org.apache.maven.AbstractMavenLifecycleParticipant</role>
      <implementation>${package}.${capitalizedExtension}ArtifactExtension</implementation>
    </component>
  </components>
</component-set>