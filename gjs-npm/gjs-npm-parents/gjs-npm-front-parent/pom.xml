<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

	<parent>
		<groupId>org.gjs.npm</groupId>
		<artifactId>gjs-npm-parent</artifactId>
		<version>1.0.0-RC.1</version>
		<relativePath>../gjs-npm-parent</relativePath>
	</parent>	

    <groupId>org.gjs.npm</groupId>
    <artifactId>gjs-npm-front-parent</artifactId>
    <version>1.0.0-RC.1</version>
	<packaging>pom</packaging>

	<name>GJS Npm</name>
	<description>
		GJS Npm front integration with Maven.
		Profiles:
		* angular (default) | react | vue   
	</description>

	<properties>
		<!-- Npm configuration -->
        <!-- Carpeta de salida (Angular/React/Vue suelen usar dist o build) -->
        <frontend.output.dir>${working.dir}/dist</frontend.output.dir>
        <!-- Puedes cambiar a build si usas React clásico -->
        <!-- <frontend.output.dir>${working.dir}/build</frontend.output.dir> -->
	</properties>
	
	<build>
		<pluginManagement>
			<plugins>
				<!-- Copiar build frontend -->
				<plugin>
					<artifactId>maven-resources-plugin</artifactId>
					<executions>
						<execution>
							<id>copy-frontend</id>
							<phase>process-resources</phase>
							<goals>
								<goal>copy-resources</goal>
							</goals>
							<configuration>
								<outputDirectory>${project.build.directory}/frontend</outputDirectory>
								<resources>
									<resource>
										<directory>${frontend.output.dir}</directory>
										<filtering>false</filtering>
									</resource>
								</resources>
							</configuration>
						</execution>
					</executions>
				</plugin>
			</plugins>
		</pluginManagement>		

		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-enforcer-plugin</artifactId>
				<executions>
					<execution>
						<id>enforce-profiles-npm-ok</id>
						<goals>
							<goal>enforce</goal>
						</goals>
						<configuration>
							<rules>
								<requireActiveProfile>
									<profiles>angular,react,vue</profiles>
									<all>false</all>
								</requireActiveProfile>
							</rules>
							<fail>true</fail>
						</configuration>
					</execution>
				</executions>
			</plugin>  
			<plugin>
				<artifactId>maven-resources-plugin</artifactId>
				<configuration>
					<skip>${skip.if.not.source}</skip>
				</configuration>
            </plugin>
		</plugins>
	</build>

    <profiles>
		<!-- React suele usar build en lugar de dist -->
        <profile>
            <id>react</id>
            <properties>
                <frontend.output.dir>${working.dir}/build</frontend.output.dir>
				<!-- Global install -->
				<global.install.libs>@angular/cli vite@latest</global.install.libs>
            </properties>
        </profile>

        <!-- Angular/Vue (por defecto dist) -->
        <profile>
            <id>angular</id>
			<activation>
				<activeByDefault>true</activeByDefault>
			</activation>
			<properties>
				<!-- Global install -->
				<global.install.libs>@angular/cli</global.install.libs>
			</properties>
        </profile>

        <profile>
            <id>vue</id>
			<properties>
				<!-- Global install -->
				<global.install.libs>vue@latest</global.install.libs>
			</properties>
        </profile>
    </profiles>

</project>