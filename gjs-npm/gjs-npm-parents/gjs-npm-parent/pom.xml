<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

	<parent>
		<groupId>org.gjs</groupId>
		<artifactId>gjs-parent</artifactId>
		<version>1.0.0-RC.1</version>
		<relativePath>../../../gjs-parent</relativePath>
	</parent>	

    <groupId>org.gjs.npm</groupId>
    <artifactId>gjs-npm-parent</artifactId>
    <version>1.0.0-RC.1</version>
	<packaging>pom</packaging>

	<name>GJS Npm</name>
	<description>
		GJS Npm integration with Maven.
		
		Fase Maven			Comando npm equivalente
		initialize			npm install
		process-sources		npm run lint (opcional)
		generate-resources	npm run build
		test				npm test
		package				npm run package (opcional)
		
		Profiles:
		* dev (default) | pro   
		* ci
		* pnpm
		* pnpm-ci
		* install	
		
		Install libraries:
			mvn exec:exec@pm-global-install -Pinstall
	</description>

	<properties>
		<!-- Default programming language features -->
		<gjs.source.language>typescript</gjs.source.language>
		<gjs.source.extension>ts</gjs.source.extension>

		<!-- Npm configuration -->
		<!-- Selector de gestor: npm | pnpm -->
        <package.manager>npm</package.manager>
        <node.env></node.env>
        <install.command></install.command>
        <build.script>build</build.script>
        <test.script>test</test.script>
        <npm.build.dir>${project.build.directory}/npm</npm.build.dir>
        <working.dir>${npm.build.dir}</working.dir>
		<install.args.extra></install.args.extra>
		<!-- Global install -->
		<global.install.skip>false</global.install.skip>  <!-- Automated variable: do not touch -->
		<global.install.minimal.libs>eslint</global.install.minimal.libs>  
		<global.install.libs></global.install.libs>  <!-- Library names separated by a space -->
		<local.install.minimal.libs>globals @eslint/js typescript-eslint</local.install.minimal.libs>  
		<local.install.libs></local.install.libs>  <!-- Library names separated by a space -->
	</properties>
	
	<build>
		<pluginManagement>
			<plugins>
				<plugin>
					<artifactId>maven-antrun-plugin</artifactId>
					<executions>
						<execution>
							<id>initilize-properties</id>
							<phase>initialize</phase>
							<goals>
								<goal>run</goal>
							</goals>
							<configuration>
								<target>
									<condition property="global.install.skip" value="false" else="true">
										<isset property="global.install.libs"/>
									</condition>
								</target>
							</configuration>
						</execution>
					</executions>
				</plugin>
				<plugin>
					<artifactId>maven-resources-plugin</artifactId>
					<executions>
						<execution>
							<id>copy-sources</id>
							<phase>initialize</phase>
							<goals>
								<goal>copy-resources</goal>
							</goals>
							<configuration>
								<outputDirectory>${npm.build.dir}</outputDirectory>
								<resources>
									<resource>
										<directory>${project.basedir}</directory>
										<filtering>false</filtering>
										<excludes>
											<exclude>pom.xml</exclude>
										</excludes>
									</resource>
								</resources>
							</configuration>
						</execution>
					</executions>
				</plugin>
				<plugin>
					<groupId>org.codehaus.mojo</groupId>
					<artifactId>exec-maven-plugin</artifactId>
					<executions>
						<!-- Install -->
						<execution>
							<id>pm-install</id>
							<phase>initialize</phase>
							<goals><goal>exec</goal></goals>
							<configuration>
								<workingDirectory>${working.dir}</workingDirectory>
								<executable>${package.manager}</executable>
								<environmentVariables>
									<NODE_ENV>${node.env}</NODE_ENV>
								</environmentVariables>
								<arguments>
									<argument>${install.command}</argument>
									<argument>${install.args.extra}</argument>
								</arguments>
							</configuration>
						</execution>
						<!-- Additional local installations -->
						<execution>
							<id>pm-local-install</id>
							<phase>initialize</phase>
							<goals>
								<goal>exec</goal>
							</goals>
							<configuration>
								<skip>${global.install.skip}</skip>
								<workingDirectory>${working.dir}</workingDirectory>
								<executable>${console}</executable>
								<environmentVariables>
									<NODE_ENV>${node.env}</NODE_ENV>
								</environmentVariables>
								<arguments>
									<argument>${consoleArgs}</argument>
									<argument>${package.manager} ${install.command} --save-dev ${local.install.minimal.libs} ${local.install.libs}</argument>
								</arguments>
							</configuration>
						</execution>

						<!-- Build -->
						<execution>
							<id>pm-build</id>
							<phase>generate-resources</phase>
							<goals><goal>exec</goal></goals>
							<configuration>
								<workingDirectory>${working.dir}</workingDirectory>
								<executable>${package.manager}</executable>
								<arguments>
									<argument>run</argument>
									<argument>${build.script}</argument>
								</arguments>
							</configuration>
						</execution>

						<!-- Test -->
						<execution>
							<id>pm-test</id>
							<phase>test</phase>
							<goals><goal>exec</goal></goals>
							<configuration>
								<workingDirectory>${working.dir}</workingDirectory>
								<executable>${package.manager}</executable>
								<arguments>
									<argument>run</argument>
									<argument>${test.script}</argument>
								</arguments>
							</configuration>
						</execution>

						<!-- npm run lint (opcional) -->
						<execution>
							<id>npm-lint</id>
							<phase>process-sources</phase>
							<goals>
								<goal>exec</goal>
							</goals>
							<configuration>
								<workingDirectory>${working.dir}</workingDirectory>
								<executable>npm</executable>
								<arguments>
									<argument>run</argument>
									<argument>lint</argument>
								</arguments>
							</configuration>
						</execution>

						<!-- npm run package (opcional) -->
						<execution>
							<id>npm-package</id>
							<phase>package</phase>
							<goals>
								<goal>exec</goal>
							</goals>
							<configuration>
								<workingDirectory>${working.dir}</workingDirectory>
								<executable>npm</executable>
								<arguments>
									<argument>run</argument>
									<argument>package</argument>
								</arguments>
							</configuration>
						</execution>
					</executions>
				</plugin>
				<!--
				<plugin>
					<artifactId>maven-antrun-plugin</artifactId>
					<executions>
						<execution>
							<id>move-tgz</id>
							<phase>package</phase>
							<goals>
								<goal>run</goal>
							</goals>
							<configuration>
								<target>
									<move todir="${project.build.directory}" flatten="true">
										<fileset dir="${working.dir}">
											<include name="*.tgz"/>
										</fileset>
									</move>
								</target>
							</configuration>
						</execution>
					</executions>
				</plugin>
				-->

				<!-- Limpieza adicional -->
				<plugin>
					<artifactId>maven-clean-plugin</artifactId>
					<configuration>
						<filesets>
							<fileset>
								<directory>${working.dir}/dist</directory>
								<directory>${working.dir}/node-modules</directory>
							</fileset>
						</filesets>
					</configuration>
				</plugin>
			</plugins>
		</pluginManagement>		

		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-enforcer-plugin</artifactId>
				<executions>
					<execution>
						<id>enforce-profiles-npm-ok</id>
						<goals>
							<goal>enforce</goal>
						</goals>
						<configuration>
							<rules>
								<requireActiveProfile>
									<profiles>dev,pro,install</profiles>
									<all>false</all>
								</requireActiveProfile>
							</rules>
							<fail>true</fail>
						</configuration>
					</execution>
				</executions>
			</plugin>  
			<plugin>
				<artifactId>maven-antrun-plugin</artifactId>
            </plugin>
			<plugin>
				<artifactId>maven-resources-plugin</artifactId>
				<configuration>
					<skip>${skip.if.not.source}</skip>
				</configuration>
            </plugin>
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>exec-maven-plugin</artifactId>
				<configuration>
					<skip>${skip.if.not.source}</skip>
				</configuration>
            </plugin>
			<plugin>
				<artifactId>maven-jar-plugin</artifactId>
				<executions>
					<execution>
						<id>default-jar</id>
						<phase>none</phase>
					</execution>
				</executions>
			</plugin>
		</plugins>
	</build>

    <profiles>
        <!-- Desarrollo -->
        <profile>
            <id>dev</id>
			<activation>
				<activeByDefault>true</activeByDefault>
			</activation>
            <properties>
                <node.env>development</node.env>
                <install.command>install</install.command>
            </properties>
        </profile>
        <!-- Produccion -->
        <profile>
            <id>pro</id>
            <properties>
				<node.env>production</node.env>
				<install.command>ci</install.command>
            </properties>
        </profile>
        <!-- CI -->
        <profile>
            <id>ci</id>
            <properties>
                <install.command>ci</install.command>
            </properties>
        </profile>
        <!-- Usar pnpm -->
        <profile>
            <id>pnpm</id>
            <properties>
                <package.manager>pnpm</package.manager>
            </properties>
        </profile>
		<profile>
			<id>pnpm-ci</id>
			<properties>
				<package.manager>pnpm</package.manager>
				<install.command>install</install.command>
				<install.args.extra>--frozen-lockfile</install.args.extra>
			</properties>
		</profile>
		<profile>
			<id>install</id>
			<build>
				<plugins>
					<plugin>
						<groupId>org.codehaus.mojo</groupId>
						<artifactId>exec-maven-plugin</artifactId>
						<executions>
							<!-- Install -->
							<execution>
								<id>pm-global-install</id>
								<phase>validate</phase>
								<goals>
									<goal>exec</goal>
								</goals>
								<configuration>
									<skip>${global.install.skip}</skip>
									<workingDirectory>${working.dir}</workingDirectory>
									<executable>${console}</executable>
									<environmentVariables>
										<NODE_ENV>${node.env}</NODE_ENV>
									</environmentVariables>
									<arguments>
										<argument>${consoleArgs}</argument>
										<argument>${package.manager} ${install.command} -g ${global.install.minimal.libs} ${global.install.libs}</argument>
									</arguments>
								</configuration>
							</execution>
						</executions>
					</plugin>
				</plugins>
			</build>
		</profile>
    </profiles>


</project>