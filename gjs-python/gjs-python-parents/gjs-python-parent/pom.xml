<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

	<parent>
		<groupId>org.gjs</groupId>
		<artifactId>gjs-parent</artifactId>
		<version>1.0.0-RC.1</version>
		<relativePath>../../../gjs-parent</relativePath>
	</parent>	

    <groupId>org.gjs.python</groupId>
    <artifactId>gjs-python-parent</artifactId>
    <version>1.0.0-RC.1</version>
	<packaging>pom</packaging>

	<name>GJS common Python base parent</name>
	<description>
		Maven Python general parent pom.
		
		Fase Maven			Comando npm equivalente
		initialize			
		compile				pip install
		test				python -m pytest
		package				python -m build
		install				pip install
		
		Profiles:
		* upgrade	
		
		Install libraries:
			mvn exec:exec@upgrade-tools -Pupgrade
	</description>

	<properties>
		<!-- Default programming language features -->
		<gjs.source.language>python</gjs.source.language>
		<gjs.source.extension>py</gjs.source.extension>
		
		<!-- Python/Pip configuration -->
		<gjs.python.dir.build>${project.build.directory}/python-build</gjs.python.dir.build>
		<gjs.python.dir.eggs>${project.build.directory}/python-eggs</gjs.python.dir.eggs>
		<gjs.python.dir.src>${project.build.directory}/python-src</gjs.python.dir.src>
		<gjs.python.artifact.ext>tar.gz</gjs.python.artifact.ext>
		<gjs.python.artifact.src.package.path>org/gjs/python</gjs.python.artifact.src.package.path>
	</properties>
	
	<build>
		<pluginManagement>
			<plugins>
				<plugin>
					<artifactId>maven-resources-plugin</artifactId>
					<executions>
						<execution>
							<id>copy-python-sources</id>
							<phase>generate-resources</phase>
							<goals><goal>copy-resources</goal></goals>
							<configuration>
								<outputDirectory>${gjs.python.dir.src}</outputDirectory>
								<resources>
									<resource>
										<directory>${project.basedir}</directory>
										<includes>
											<include>src/**</include>
											<include>pyproject.toml</include>
											<include>setup.py</include>
										</includes>
									</resource>
								</resources>
							</configuration>
						</execution>
					</executions>
				</plugin>
				<plugin>
					<artifactId>maven-antrun-plugin</artifactId>
					<executions>
						<execution>
							<phase>initialize</phase>
							<goals>
								<goal>run</goal>
							</goals>
							<configuration>
								<target>
									<mkdir dir="${gjs.python.dir.src}"/>
								</target>
							</configuration>
						</execution>
					</executions>
				</plugin>
				<plugin>
					<groupId>org.codehaus.mojo</groupId>
					<artifactId>exec-maven-plugin</artifactId>
					<executions>
						<execution>
							<id>python-clean</id>
							<phase>clean</phase>
							<goals>
								<goal>exec</goal>
							</goals>
							<configuration>
								<executable>python</executable>
								<arguments>
									<argument>-c</argument>
									<argument>import shutil, os; [shutil.rmtree(d) for d in ['dist', 'build', 'target'] if os.path.exists(d)]</argument>
								</arguments>
							</configuration>
						</execution>
						<execution>
							<id>python-setup</id>
							<phase>compile</phase>
							<goals>
								<goal>exec</goal>
							</goals>
							<configuration>
								<executable>pip</executable>
								<workingDirectory>${gjs.python.dir.src}</workingDirectory>
								<arguments>
									<argument>install</argument>
									<argument>.</argument>
								</arguments>
							</configuration>
						</execution>
						<execution>
							<id>python-test</id>
							<phase>test</phase>
							<goals>
								<goal>exec</goal>
							</goals>
							<configuration>
								<executable>python</executable>
								<workingDirectory>${gjs.python.dir.src}</workingDirectory>
								<arguments>
									<argument>-m</argument>
									<argument>pytest</argument>
									<argument>--junitxml=../target/surefire-reports/python-tests.xml</argument>
								</arguments>
							</configuration>
						</execution>
						<execution>
							<id>python-package</id>
							<phase>prepare-package</phase>
							<goals>
								<goal>exec</goal>
							</goals>
							<configuration>
								<executable>python</executable>
								<workingDirectory>${gjs.python.dir.src}</workingDirectory>
								<arguments>
									<argument>-m</argument>
									<argument>build</argument>
									<argument>--outdir</argument>
									<argument>${project.build.directory}</argument> 
								</arguments>
							</configuration>
						</execution>
					</executions>
				</plugin>
				<!--
				<plugin>
					<artifactId>maven-antrun-plugin</artifactId>
					<executions>
						<execution>
							<id>python-rename-package</id>
							<phase>package</phase>
							<goals>
								<goal>run</goal>
							</goals>
							<configuration>
								<target>
									<move todir="${project.build.directory}">
										<fileset dir="${project.build.directory}">
											<include name="*.${gjs.python.artifact.ext}" />
										</fileset>
										<mapper type="glob" from="*.${gjs.python.artifact.ext}" to="${project.build.finalName}.${gjs.python.artifact.ext}" />
									</move>
									<echo level="info" message="Package created: ${project.build.finalName}.${gjs.python.artifact.ext}" />
								</target>
							</configuration>
						</execution>
					</executions>
				</plugin>
				-->
			</plugins>
		</pluginManagement>		

		<plugins>
			<plugin>
				<artifactId>maven-antrun-plugin</artifactId>
				<configuration>
					<skip>${skip.if.not.source}</skip>
				</configuration>
            </plugin>
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>exec-maven-plugin</artifactId>
				<configuration>
					<skip>${skip.if.not.source}</skip>
				</configuration>
            </plugin>
			<plugin>
				<artifactId>maven-jar-plugin</artifactId>
				<executions>
					<execution>
						<id>default-jar</id>
						<phase>none</phase>
					</execution>
				</executions>
			</plugin>
		</plugins>
	</build>

    <profiles>
		<profile>
            <id>upgrade</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>exec-maven-plugin</artifactId>
						<configuration>
							<skip>${skip.if.not.source}</skip>
						</configuration>
                       <executions>
                            <execution>
                                <id>upgrade-tools</id>
                                <phase>initialize</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>python</executable>
                                    <arguments>
										<argument>-m</argument> 
										<argument>pip</argument>
										<argument>install</argument>
										<argument>--upgrade</argument>
										<argument>pip</argument>
										<argument>setuptools</argument>
										<argument>wheel</argument>
										<argument>build</argument>
										<argument>pytest</argument>
									</arguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>       
                </plugins>       
            </build>
        </profile>
    </profiles>

</project>