<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

	<parent>
		<groupId>org.gjs.python</groupId>
		<artifactId>gjs-python-parent</artifactId>
		<version>1.0.0-RC.1</version>
		<relativePath>../gjs-python-parent</relativePath>
	</parent>	

    <groupId>org.gjs.python</groupId>
    <artifactId>gjs-python-exe-parent</artifactId>
    <version>1.0.0-RC.1</version>
	<packaging>pom</packaging>

	<name>GJS common Python Exe parent</name>
	<description>
		Maven Python general parent for executables pom.
	</description>

	<properties>
		<gjs.python.artifact.ext>pyz</gjs.python.artifact.ext>
		<gjs.python.artifact.src.path>.</gjs.python.artifact.src.path>
		<gjs.python.artifact.main>Main:main</gjs.python.artifact.main>
		
		<!-- Extensions versions -->
		<pyz-maven-extension.version>1.0.0-RC.1</pyz-maven-extension.version>
	</properties>
	
	<build>
		<pluginManagement>
			<plugins>
				<plugin>
					<groupId>org.codehaus.mojo</groupId>
					<artifactId>exec-maven-plugin</artifactId>
					<executions>
						<execution>
							<id>python-package</id>
							<phase>package</phase>
							<goals>
								<goal>exec</goal>
							</goals>
							<configuration self.combine="overvrite">
								<executable>python</executable>
								<workingDirectory>${gjs.python.dir.src}</workingDirectory>
								<arguments>
									<argument>-m</argument>
									<argument>zipapp</argument>
									<argument>${gjs.python.artifact.src.path}</argument> 
									<argument>-o</argument>
									<argument>${project.build.directory}/${project.build.finalName}.${gjs.python.artifact.ext}</argument> 
									<argument>--main</argument>
									<argument>${gjs.python.artifact.main}</argument> 
								</arguments>
							</configuration>
						</execution>
					</executions>
				</plugin>
			</plugins>
		</pluginManagement>		

		<extensions>
			<extension>
				<groupId>org.gjs.maven.extensions</groupId>
				<artifactId>pyz-maven-extension</artifactId>
				<version>${pyz-maven-extension.version}</version>
			</extension>
		</extensions>
	</build>

</project>